{% doc %}
  @prompt
    Bueno, me gustaría que diseñaras un bloque que fuera de varias secciones que fueran cambiando una por una cada cierto tiempo. En una, por ejemplo, pusiera como oferta de productos de tecnología y apareciera como una especie de collage con varios productos de tecnología. Luego, a la derecha, pasaría a la siguiente imagen y que ésta diga: "¿Ya viste nuestros nuevos productos de aseo?" y así con cuatro categorías diferentes.
    
    Evidentemente, estos productos aún no los tengo en esta página, pero serían como más que todo para que destaque de forma visual. Entonces sería importante que me ayudara con eso. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-category-carousel-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-category-carousel__slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 600px;
  }

  @media screen and (max-width: 749px) {
    .ai-category-carousel__slides-{{ ai_gen_id }} {
      height: 500px;
    }
  }

  .ai-category-carousel__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease-in-out, visibility 0.6s ease-in-out;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.slide_background }};
  }

  .ai-category-carousel__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .ai-category-carousel__content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1200px;
    padding: 40px;
    gap: 40px;
  }

  @media screen and (max-width: 749px) {
    .ai-category-carousel__content-{{ ai_gen_id }} {
      flex-direction: column;
      padding: 20px;
      gap: 20px;
    }
  }

  .ai-category-carousel__text-{{ ai_gen_id }} {
    flex: 1;
    max-width: 500px;
  }

  .ai-category-carousel__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    line-height: 1.2;
  }

  @media screen and (max-width: 749px) {
    .ai-category-carousel__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }
  }

  .ai-category-carousel__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
    line-height: 1.5;
  }

  .ai-category-carousel__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: 14px;
    text-transform: uppercase;
    transition: background-color 0.3s ease;
  }

  .ai-category-carousel__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-category-carousel__collage-{{ ai_gen_id }} {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: 12px;
    max-width: 500px;
    height: 400px;
  }

  @media screen and (max-width: 749px) {
    .ai-category-carousel__collage-{{ ai_gen_id }} {
      height: 300px;
      max-width: 100%;
    }
  }

  .ai-category-carousel__collage-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-category-carousel__collage-item-{{ ai_gen_id }}:first-child {
    grid-row: span 2;
  }

  .ai-category-carousel__collage-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-category-carousel__collage-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-category-carousel__collage-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-category-carousel__indicators-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 2;
  }

  .ai-category-carousel__indicator-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.indicator_color }};
    opacity: 0.4;
    cursor: pointer;
    border: none;
    padding: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-category-carousel__indicator-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.2);
  }

  .ai-category-carousel__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_background }};
    color: {{ block.settings.nav_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background-color 0.3s ease;
  }

  .ai-category-carousel__nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_background }};
  }

  .ai-category-carousel__nav-{{ ai_gen_id }}--prev {
    left: 20px;
  }

  .ai-category-carousel__nav-{{ ai_gen_id }}--next {
    right: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-category-carousel__nav-{{ ai_gen_id }} {
      width: 32px;
      height: 32px;
    }

    .ai-category-carousel__nav-{{ ai_gen_id }}--prev {
      left: 10px;
    }

    .ai-category-carousel__nav-{{ ai_gen_id }}--next {
      right: 10px;
    }
  }
{% endstyle %}

<category-carousel-{{ ai_gen_id }} class="ai-category-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-category-carousel__slides-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign title_key = 'category_' | append: i | append: '_title'
        assign description_key = 'category_' | append: i | append: '_description'
        assign button_text_key = 'category_' | append: i | append: '_button_text'
        assign button_link_key = 'category_' | append: i | append: '_button_link'
        assign image1_key = 'category_' | append: i | append: '_image_1'
        assign image2_key = 'category_' | append: i | append: '_image_2'
        assign image3_key = 'category_' | append: i | append: '_image_3'
        assign image4_key = 'category_' | append: i | append: '_image_4'

        assign title = block.settings[title_key]
        assign description = block.settings[description_key]
        assign button_text = block.settings[button_text_key]
        assign button_link = block.settings[button_link_key]
        assign image1 = block.settings[image1_key]
        assign image2 = block.settings[image2_key]
        assign image3 = block.settings[image3_key]
        assign image4 = block.settings[image4_key]
      %}

      <div class="ai-category-carousel__slide-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}" data-slide="{{ i }}">
        <div class="ai-category-carousel__content-{{ ai_gen_id }}">
          <div class="ai-category-carousel__text-{{ ai_gen_id }}">
            {% if title != blank %}
              <h2 class="ai-category-carousel__title-{{ ai_gen_id }}">{{ title }}</h2>
            {% endif %}
            {% if description != blank %}
              <p class="ai-category-carousel__description-{{ ai_gen_id }}">{{ description }}</p>
            {% endif %}
            {% if button_text != blank %}
              <a href="{{ button_link }}" class="ai-category-carousel__button-{{ ai_gen_id }}">
                {{ button_text }}
              </a>
            {% endif %}
          </div>

          <div class="ai-category-carousel__collage-{{ ai_gen_id }}">
            <div class="ai-category-carousel__collage-item-{{ ai_gen_id }}">
              {% if image1 %}
                <img
                  src="{{ image1 | image_url: width: 600 }}"
                  alt="{{ image1.alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="ai-category-carousel__collage-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-category-carousel__collage-item-{{ ai_gen_id }}">
              {% if image2 %}
                <img
                  src="{{ image2 | image_url: width: 300 }}"
                  alt="{{ image2.alt | escape }}"
                  loading="lazy"
                  width="300"
                  height="300"
                >
              {% else %}
                <div class="ai-category-carousel__collage-placeholder-{{ ai_gen_id }}">
                  {{ 'product-2' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-category-carousel__collage-item-{{ ai_gen_id }}">
              {% if image3 %}
                <img
                  src="{{ image3 | image_url: width: 300 }}"
                  alt="{{ image3.alt | escape }}"
                  loading="lazy"
                  width="300"
                  height="300"
                >
              {% else %}
                <div class="ai-category-carousel__collage-placeholder-{{ ai_gen_id }}">
                  {{ 'product-3' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  {% if block.settings.show_navigation %}
    <button class="ai-category-carousel__nav-{{ ai_gen_id }} ai-category-carousel__nav-{{ ai_gen_id }}--prev" aria-label="Anterior">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
    <button class="ai-category-carousel__nav-{{ ai_gen_id }} ai-category-carousel__nav-{{ ai_gen_id }}--next" aria-label="Siguiente">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  {% endif %}

  {% if block.settings.show_indicators %}
    <div class="ai-category-carousel__indicators-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        <button
          class="ai-category-carousel__indicator-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
          data-slide="{{ i }}"
          aria-label="Ir a categoría {{ i }}"
        ></button>
      {% endfor %}
    </div>
  {% endif %}
</category-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class CategoryCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 1;
        this.totalSlides = 4;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = this.querySelectorAll('.ai-category-carousel__slide-{{ ai_gen_id }}');
        this.indicators = this.querySelectorAll('.ai-category-carousel__indicator-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-category-carousel__nav-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-category-carousel__nav-{{ ai_gen_id }}--next');

        this.setupEventListeners();
        
        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.goToSlide(this.currentSlide === 1 ? this.totalSlides : this.currentSlide - 1);
            this.resetAutoplay();
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.goToSlide(this.currentSlide === this.totalSlides ? 1 : this.currentSlide + 1);
            this.resetAutoplay();
          });
        }

        this.indicators.forEach((indicator) => {
          indicator.addEventListener('click', (e) => {
            const slideNumber = parseInt(e.target.dataset.slide);
            this.goToSlide(slideNumber);
            this.resetAutoplay();
          });
        });
      }

      goToSlide(slideNumber) {
        this.slides.forEach((slide) => {
          slide.classList.remove('active');
        });

        this.indicators.forEach((indicator) => {
          indicator.classList.remove('active');
        });

        const targetSlide = this.querySelector(`[data-slide="${slideNumber}"].ai-category-carousel__slide-{{ ai_gen_id }}`);
        const targetIndicator = this.querySelector(`[data-slide="${slideNumber}"].ai-category-carousel__indicator-{{ ai_gen_id }}`);

        if (targetSlide) {
          targetSlide.classList.add('active');
        }

        if (targetIndicator) {
          targetIndicator.classList.add('active');
        }

        this.currentSlide = slideNumber;
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          const nextSlide = this.currentSlide === this.totalSlides ? 1 : this.currentSlide + 1;
          this.goToSlide(nextSlide);
        }, {{ block.settings.autoplay_speed | times: 1000 }});
      }

      resetAutoplay() {
        {% if block.settings.autoplay %}
          if (this.autoplayInterval) {
            clearInterval(this.autoplayInterval);
          }
          this.startAutoplay();
        {% endif %}
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('category-carousel-{{ ai_gen_id }}', CategoryCarousel{{ ai_gen_id }});
  })();
</script>

